---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Yoni's Digital Garden — Living Resume & Knowledge Base" } = Astro.props;
const currentPath = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL;
const root = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;
const withBase = (path: string) => `${root}${path}`;
const nav = [
  { href: withBase('/'), label: 'Home' },
  { href: withBase('/resume'), label: 'Resume' },
  { href: withBase('/projects'), label: 'Projects' },
  { href: withBase('/goals'), label: 'Goals' },
  { href: withBase('/now'), label: 'Now' },
  { href: withBase('/blog'), label: 'Research' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="shell">
        <a class="brand" href={withBase('/')}>Yonatan Yagudaev</a>
        <nav class="site-nav" aria-label="Primary">
          {
            nav.map((item) => (
              <a class={currentPath === item.href ? 'active' : ''} href={item.href}>
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <main class="shell">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell">
        <p>Living Resume · Notion Sync · Astro · GitHub Pages</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
