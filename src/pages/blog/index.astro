---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const baseUrl = import.meta.env.BASE_URL;
const root = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;
const withBase = (path: string) => `${root}${path}`;
---

<BaseLayout title="Blog — Yoni's Digital Garden" description="Notes and research synced from Notion.">
  <section class="hero">
    <h1>Networking Research</h1>
    <p class="lede">Deep research notes synced from Notion.</p>
  </section>

  <ul class="clean" style="margin-top: 1rem;">
      {posts.map((post) => (
        <li class="card">
          <a href={withBase(`/blog/${post.id}`)} style="font-weight: 500;">{post.data.title}</a>
          <time class="muted" datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-CA', { dateStyle: 'medium' })}
          </time>
        </li>
      ))}
  </ul>
  {posts.length === 0 && (
    <p class="muted">No posts yet. Run the Notion sync to pull content.</p>
  )}
</BaseLayout>
